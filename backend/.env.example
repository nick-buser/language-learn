# Polyglot Atlas API — local config template. Copy to .env (gitignored).
# All settings are read by pydantic-settings with the PA_ prefix (config.py).

PA_ENVIRONMENT=dev

# Sync SQLAlchemy + psycopg3 DSN. Local throwaway Postgres for development;
# the homelab dev/prod DSN is injected at deploy time from the vault, never here.
PA_DATABASE_URL=postgresql+psycopg://polyglot:polyglot@localhost:5433/polyglot_atlas

# CORS — the Vite SPA dev origin(s), comma-separated.
PA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

PA_LOG_LEVEL=INFO
