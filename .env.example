# The Polyglot's Atlas — frontend env (Vite). Copy to .env (gitignored).
# Only VITE_-prefixed vars are exposed to the SPA.

# Backend base URL — controls where the dictionary is read from:
#   (unset)            local only — the bundled ko.json, no network (default)
#   VITE_API_URL=      same-origin — call /v1 on the host serving the SPA
#                      (the container build sets this; with `npm run dev` the
#                       Vite proxy forwards /v1 to a local backend on :8000)
#   VITE_API_URL=URL   a separate backend origin (e.g. local dev or staging)
# VITE_API_URL=
# VITE_API_URL=http://localhost:8000
