# The Polyglot's Atlas — frontend env (Vite). Copy to .env (gitignored).
# Only VITE_-prefixed vars are exposed to the SPA.

# Backend base URL. Set this to read the dictionary from the homelab API;
# unset (the default) the SPA serves the bundled local ko.json, so nothing
# requires the backend to be running.
# VITE_API_URL=https://polyglot-atlas.app.bittern-chameleon.dev
